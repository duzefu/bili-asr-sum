# ASR 提供商：aliyun 或 volcengine
ASR_PROVIDER=aliyun

# 阿里云 DashScope API Key（ASR_PROVIDER=aliyun 时必须）
ALIYUN_DASHSCOPE_API_KEY=

# 火山引擎豆包 ASR（ASR_PROVIDER=volcengine 时必须）
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_TOKEN=

# DeepSeek API Key（必须）
DEEPSEEK_API_KEY=

# 服务的公网地址，用于 ASR API 抓取临时音频文件（必须）
# 例如：https://example.com 或 http://1.2.3.4:8000
SERVER_BASE_URL=https://your-server.com
