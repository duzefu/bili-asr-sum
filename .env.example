# ASR 提供商：aliyun、volcengine 或 local_sensevoice（本地离线）
ASR_PROVIDER=aliyun

# 阿里云 DashScope API Key（ASR_PROVIDER=aliyun 时必须）
ALIYUN_DASHSCOPE_API_KEY=

# 火山引擎豆包 ASR（ASR_PROVIDER=volcengine 时必须）
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_TOKEN=

# 本地 SenseVoice 离线 ASR（ASR_PROVIDER=local_sensevoice 时生效，无需 API Key）
# 首次运行会自动从 ModelScope 下载模型（~500MB）
# LOCAL_ASR_DEVICE=cpu          # cpu / cuda:0 / mps
# LOCAL_ASR_LANGUAGE=auto       # auto / zh / en / ja / ko / yue

# DeepSeek API Key（必须）
DEEPSEEK_API_KEY=

# 内容缓存后端：memory（默认，进程内）或 upstash（Upstash Redis）
CACHE_BACKEND=memory

# 缓存过期时间（秒，默认 30 天）
# CACHE_TTL_SECONDS=2592000

# 是否同时缓存原文（默认 false，节省存储空间）
# CACHE_STORE_TRANSCRIPT=false

# Upstash Redis REST API（CACHE_BACKEND=upstash 时必填）
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxxxx
